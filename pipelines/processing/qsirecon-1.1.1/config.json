{
    "NAME": "qsirecon",
    "VERSION": "1.1.1",
    "CONTAINER_INFO": {
        "FILE": "[[NIPOPPY_DPATH_CONTAINERS]]/[[PIPELINE_NAME]]_[[PIPELINE_VERSION]].sif",
        "URI": "docker://pennlinc/[[PIPELINE_NAME]]:[[PIPELINE_VERSION]]"
    },
    "CONTAINER_CONFIG": {
        "ENV_VARS": {
            "TEMPLATEFLOW_HOME": "[[TEMPLATEFLOW_HOME]]"
        },
        "ARGS": [
            "--bind",
            "[[FREESURFER_LICENSE_FILE]]",
            "--bind",
            "[[TEMPLATEFLOW_HOME]]"
        ]
    },
    "STEPS": [
        {
            "NAME": "dsi_studio_autotrack",
            "INVOCATION_FILE": "dsi_studio_autotrack-invocation.json",
            "DESCRIPTOR_FILE": "descriptor.json",
            "HPC_CONFIG_FILE": "hpc.json",
            "TRACKER_CONFIG_FILE": "dsi_studio_autotrack-tracker.json",
	        "PYBIDS_IGNORE_FILE": "pybids_ignore.json"
        },
        {
            "NAME": "mrtrix_multishell_msmt_ACT-hsvs",
            "INVOCATION_FILE": "mrtrix_multishell_msmt_ACT-hsvs-invocation.json",
            "DESCRIPTOR_FILE": "descriptor.json",
            "HPC_CONFIG_FILE": "hpc.json",
            "TRACKER_CONFIG_FILE": "mrtrix_multishell_msmt_ACT-hsvs-tracker.json",
	        "PYBIDS_IGNORE_FILE": "pybids_ignore.json"
        }

        
    ],
    "VARIABLES": {
        "FREESURFER_LICENSE_FILE": "Path to FreeSurfer license file",
        "TEMPLATEFLOW_HOME": "Path to the directory where TemplateFlow will store templates (can be empty)",
        "QSIPREP_VERSION": "Version of QSIPrep to use",
        "FREESURFER_VERSION": "Version of FreeSurfer to use"
    },
    "PIPELINE_TYPE": "processing",
    "SCHEMA_VERSION": "1"
}
